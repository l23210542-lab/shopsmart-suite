# MariaDB (Raspberry Pi / Node) — variables solo servidor (no VITE_*)
# Copia a .env en la máquina de despliegue (no subas contraseñas al repositorio).

# Opción A — URL única (recomendada)
# DATABASE_URL=mysql://cenit:TU_PASSWORD@127.0.0.1:3306/cenit_pi

# Opción B — parámetros por separado
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=cenit
DB_PASSWORD=cambiar
DB_NAME=cenit_pi

# MariaDB (Raspberry Pi / Node) — solo servidor (no uses prefijo VITE_*).
# Copia este archivo a `.env` en cada máquina (no subas `.env` al repositorio).

# --- Docker (recomendado en desarrollo) ---
# Arranca MariaDB + esquema con: `npm run db:up` o la app con: `npm run dev:stack`
# (ver `docker-compose.yml`: usuario root, contraseña por defecto `devroot`, base `shopsmart`).
# En `.env` usa al menos:
#   DB_PASSWORD=devroot
#   DB_HOST=127.0.0.1
#   DB_NAME=shopsmart

# Opción A — URL única (recomendada)
# DATABASE_URL=mysql://root:devroot@127.0.0.1:3306/shopsmart

# Opción B — parámetros por separado (usa 127.0.0.1 para forzar TCP en Windows)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=devroot
DB_NAME=shopsmart

# Puerto del servidor Express opcional (server.js): PORT=3001

# Si mysql2 falla con auth_gssapi / AUTH_SWITCH_PLUGIN, crea un usuario con contraseña:
#   CREATE USER 'app'@'127.0.0.1' IDENTIFIED BY 'tu_clave';
#   GRANT ALL ON shopsmart.* TO 'app'@'127.0.0.1';
#   FLUSH PRIVILEGES;

# Esquema oficial del proyecto: `database/migrations/001_initial.sql`
# Scripts adicionales de ejemplo: carpeta `db/` (shopsmart / seed demo).
